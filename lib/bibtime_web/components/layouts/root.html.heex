<!DOCTYPE html>
<html lang={Gettext.get_locale(BibtimeWeb.Gettext)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="BibTime" suffix=" · BibTime">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body class="bg-base-100 text-base-content min-h-screen">
    <header class="bibtime-header bg-base-100 border-b border-base-300">
      <div class="max-w-7xl mx-auto flex items-center gap-6 px-4 sm:px-6 lg:px-8 h-14">
        <a href="/" class="flex items-center gap-2 group">
          <span class="text-xl font-bold tracking-tight text-primary">Bib</span><span class="text-xl font-bold tracking-tight text-base-content">Time</span>
        </a>

        <nav class="ml-auto flex items-center gap-5 text-sm">
          <%= if @current_scope do %>
            <span class="text-base-content/50 hidden sm:inline">{@current_scope.user.email}</span>
            <.link
              href={~p"/my-races"}
              class="text-base-content/70 hover:text-primary transition-colors"
            >
              {gettext("My Races")}
            </.link>
            <.link
              href={~p"/profile"}
              class="text-base-content/70 hover:text-primary transition-colors"
            >
              {gettext("Profile")}
            </.link>
            <%= if @current_scope.user.role in ["admin", "timer"] do %>
              <.link
                href={~p"/admin/races"}
                class="text-base-content/70 hover:text-primary transition-colors"
              >
                {gettext("Admin")}
              </.link>
            <% end %>
            <.link
              href={~p"/users/settings"}
              class="text-base-content/70 hover:text-primary transition-colors"
            >
              {gettext("Settings")}
            </.link>
            <.link
              href={~p"/users/log-out"}
              method="delete"
              class="text-base-content/70 hover:text-secondary transition-colors"
            >
              {gettext("Log out")}
            </.link>
          <% else %>
            <.link href={~p"/users/log-in"} class="btn btn-sm btn-primary">
              {gettext("Log in")}
            </.link>
          <% end %>
          <%!-- Language Switcher --%>
          <div class="flex items-center gap-1 text-xs">
            <%= for locale <- BibtimeWeb.Plugs.SetLocale.supported_locales() do %>
              <.link
                href={~p"/locale?locale=#{locale}"}
                method="put"
                class={[
                  "px-1.5 py-0.5 rounded font-medium transition-colors",
                  if(Gettext.get_locale(BibtimeWeb.Gettext) == locale,
                    do: "bg-primary/15 text-primary",
                    else: "text-base-content/40 hover:text-base-content/70"
                  )
                ]}
              >
                {String.upcase(locale)}
              </.link>
            <% end %>
          </div>
        </nav>
      </div>
    </header>
    {@inner_content}
  </body>
</html>
