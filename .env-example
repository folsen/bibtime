# BibTime local .env example — copy to .env and fill in.
#
# config/runtime.exs auto-loads this file in :dev and :test. Lines starting
# with `#` are ignored. Production secrets are NOT loaded from .env — set
# those via `fly secrets set` (or the systemd EnvironmentFile, etc.).
# See DEPLOY.md for the full list of variables.

# --- Stripe (test mode) -----------------------------------------------------
# Required to exercise the payments flow locally. Use the *test* keys from
# the Stripe dashboard — never put live keys in .env.
# Webhook secret comes from `stripe listen --forward-to localhost:4000/webhooks/stripe`.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# --- Dev-tools basic auth ---------------------------------------------------
# Optional in :dev — when set, /dev/mailbox, /dev/dashboard, /dev/emails
# require these credentials. Required in :staging (the app refuses to boot
# without them).
DEV_TOOLS_BASIC_AUTH_USERNAME=admin
DEV_TOOLS_BASIC_AUTH_PASSWORD=change-me

# --- Better Stack log query (scripts/logs.sh) -------------------------------
# Only needed if you want to query production logs from the terminal.
# Get these from Better Stack → Sources → your source → Connect → SQL API.
BETTERSTACK_QUERY_HOST=eu-nbg-2-connect.betterstackdata.com
BETTERSTACK_QUERY_USERNAME=replace_me
BETTERSTACK_QUERY_PASSWORD=replace_me
BETTERSTACK_QUERY_TABLE=t000000_bibtime_production_logs
# BETTERSTACK_DEBUG=1   # echo the ClickHouse SQL to stderr before each request

# --- Optional: override the dev HTTP port -----------------------------------
# PORT=4000

# --- Optional: Resend mailer ------------------------------------------------
# Leave unset in :dev — mail goes to the local Swoosh adapter and is viewable
# at /dev/mailbox. Set in production to deliver real email.
# RESEND_API_KEY=re_replace_me
# MAILER_FROM_ADDRESS=no-reply@yourdomain.com

# --- Optional: S3-compatible photo storage ----------------------------------
# Defaults to local disk. Set PHOTO_STORAGE=s3 to push participant photos to
# Tigris/R2/S3. AWS_ENDPOINT_URL_S3 is only needed for non-AWS providers.
# PHOTO_STORAGE=s3
# S3_BUCKET=bibtime-photos
# AWS_ACCESS_KEY_ID=replace_me
# AWS_SECRET_ACCESS_KEY=replace_me
# AWS_REGION=auto
# AWS_ENDPOINT_URL_S3=https://fly.storage.tigris.dev
