# /etc/default/bibtime_station
#
# Per-station environment for the BibTime timing station systemd
# service. Copy this file to /etc/default/bibtime_station on the Pi
# and fill in the real values.

# Base URL of the BibTime server (no trailing slash). Must be
# reachable from the Pi over the network.
BIBTIME_URL=http://192.168.1.231:4000

# Per-station auth token. Generate one in the BibTime admin UI under
# /admin/races/:id/stations and paste it here. Each Pi gets its own.
STATION_TOKEN=replace-me-with-real-token-from-admin-ui

# Serial port that the R200 is plugged into. /dev/ttyUSB0 is the
# default for a single CH340-based dev board on a clean Pi OS install.
# If you have multiple USB serial devices, check `dmesg | tail` after
# plugging the R200 in.
READER_DEVICE=/dev/ttyUSB0

# Where the offline buffer DETS file lives. The directory must exist
# and be writable by the bibtime user.
BUFFER_PATH=/var/lib/bibtime_station/read_buffer.dets
